% Gemini theme — adapted for joint Utah/NYUAD poster

% ====================
% Definitions
% ====================

\definecolor{themecolor}{RGB}{0,60,120}       % dark academic navy (neutral, not uni-specific)
\definecolor{lightthemecolor}{RGB}{90,130,180} % lighter accent
\definecolor{lightgray}{RGB}{240, 240, 240}
\definecolor{lightblue}{RGB}{232, 241, 252}   % light blue for alert blocks

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=themecolor}

% Headline
\setbeamercolor{headline}{fg=white,bg=themecolor}

% Block
\setbeamercolor{block title}{fg=themecolor,bg=white}
\setbeamercolor{block separator}{bg=black}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert Block
\setbeamercolor{block alerted title}{fg=themecolor,bg=lightblue}
\setbeamercolor{block alerted separator}{bg=themecolor}
\setbeamercolor{block alerted body}{fg=black,bg=lightblue}

% Example Block
\setbeamercolor{block example title}{fg=themecolor,bg=lightgray}
\setbeamercolor{block example separator}{bg=black}
\setbeamercolor{block example body}{fg=black,bg=lightgray}

% Heading
\setbeamercolor{heading}{fg=black}

% Itemize
\setbeamercolor{item}{fg=themecolor}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
